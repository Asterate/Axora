@model WebApp.ViewModels.DocumentationViewModel
@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <title>Document Dashboard</title>
</head>
<body>
<div class="col-md-12">
    <h3>Documents</h3>
    <p>
        <a asp-controller="Document" asp-action="Create" class="btn btn-success">Create New Document</a>
    </p>
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var document in Model.Documents)
        {
            <tr>
                <td>@document.DocumentName</td>
                <td>@document.DocumentType?.Description</td>
                <td>@document.CreatedAt.ToShortDateString()</td>
                <td>
                    <a asp-controller="Document" asp-action="Edit" asp-route-id="@document.Id">Edit</a> |
                    <a asp-controller="Document" asp-action="Details" asp-route-id="@document.Id">Details</a> |
                    <a asp-controller="Document" asp-action="Delete" asp-route-id="@document.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
</body>
</html>