@model WebApp.ViewModels.LookupDataViewModel

@{
    ViewData["Title"] = "Lookup Data";
}

<h1>@ViewData["Title"]</h1>

<div class="lookup-tables">

    <!-- Document Types -->
    <div class="mb-5">
        <h2>Document Types</h2>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DocumentTypes.Any())
                {
                    @foreach (var item in Model.DocumentTypes)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Description</td>
                            <td>
                                <a asp-controller="DocumentType" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a asp-controller="DocumentType" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-controller="DocumentType" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-info">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-muted">No document types found.</td></tr>
                }
            </tbody>
        </table>
        <a asp-controller="DocumentType" asp-action="Create" class="btn btn-success">Add New Document Type</a>
    </div>

