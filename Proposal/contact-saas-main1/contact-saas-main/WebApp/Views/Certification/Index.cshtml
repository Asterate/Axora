@model IEnumerable<App.Domain.Entities.Certification>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CertificationName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HandedOver)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Expired)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.InstituteUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CertificationType)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.CertificationName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HandedOver)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Expired)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.InstituteUser.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CertificationType!.Name)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
