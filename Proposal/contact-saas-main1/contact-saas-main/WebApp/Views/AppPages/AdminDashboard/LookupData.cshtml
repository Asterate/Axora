@model WebApp.ViewModels.LookupDataViewModel

@{
    ViewData["Title"] = "Lookup Data";
}

<h1>@ViewData["Title"]</h1>

<div class="lookup-tables">
    
    <!-- Certification Types -->
    <div class="mb-5">
        <h2>Certification Types</h2>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CertificationTypes.Any())
                {
                    @foreach (var item in Model.CertificationTypes)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Description</td>
                            <td>
                                <a asp-controller="CertificationType" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a asp-controller="CertificationType" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-controller="CertificationType" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-info">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-muted">No certification types found.</td></tr>
                }
            </tbody>
        </table>
        <a asp-controller="CertificationType" asp-action="Create" class="btn btn-success">Add New Certification Type</a>
    </div>

