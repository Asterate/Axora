@model WebApp.ViewModels.AnalysisDashboardViewModel
@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <title></title>
</head>
<body>
<div class="col-md-6">
    <h3>Results</h3>
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var result in Model.Results)
        {
            <tr>
                <td>@result.ResultName</td>
                <td>@result.ResultDescription</td>
                <td>@result.CreatedAt</td>
                <td>@result.UpdatedAt</td>
                <td>@result.Experiment</td>
                <td>@result.ExperimentTask</td>
                <td>@result.Unit</td>
                <td>
                    <a asp-controller="Result" asp-action="Details" asp-route-id="@result.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
</body>
</html>