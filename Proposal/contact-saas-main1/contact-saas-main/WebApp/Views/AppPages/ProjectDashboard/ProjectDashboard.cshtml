@model WebApp.ViewModels.ProjectDashboardViewModel

@{
    Layout = "_Layout";
}

<!DOCTYPE html>
<html>
<head>
    <title>Project Dashboard</title>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Left Column - Experiments Table -->
            <div class="col-md-6">
                <h3>Experiments</h3>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var experiment in Model.Experiments)
                        {
                            <tr>
                                <td>@experiment.ExperimentName</td>
                                <td>@experiment.ExperimentType?.ExperimentTypeName</td>
                                <td>@experiment.CreatedAt.ToShortDateString()</td>
                                <td>
                                    <a asp-controller="Experiment" asp-action="Details" asp-route-id="@experiment.Id">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-md-6">
                <h3>Schedule</h3>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Model.Schedules)
                        {
                            <tr>
                                <td>@schedule.ScheduleName</td>
                                <td>@schedule.Status</td>
                                <td>@schedule.StartTime.ToShortDateString()</td>
                                <td>@schedule.EndTime.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>