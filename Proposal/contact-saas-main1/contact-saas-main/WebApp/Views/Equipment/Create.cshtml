@model WebApp.ViewModels.EquipmentViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Equipment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EquipmentSerialCode" class="control-label"></label>
                <input asp-for="EquipmentSerialCode" class="form-control" />
                <span asp-validation-for="EquipmentSerialCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ManualFilePath" class="control-label"></label>
                <input asp-for="ManualFilePath" class="form-control" />
                <span asp-validation-for="ManualFilePath" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EquipmentTypeId" class="control-label"></label>
                <select asp-for="EquipmentTypeId" class ="form-control" asp-items="ViewBag.EquipmentTypeId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
