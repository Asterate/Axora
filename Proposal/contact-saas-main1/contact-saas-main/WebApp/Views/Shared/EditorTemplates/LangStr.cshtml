@model App.Domain.LangStr
@{
    // For editing, we use a simple text input with the current translated value
    var currentValue = Model?.Translate() ?? string.Empty;
    var inputId = ViewData.ModelMetadata.PropertyName;
}
<input type="text" 
       name="@inputId" 
       id="@inputId" 
       value="@currentValue" 
       class="form-control" 
       data-langstr="true" />
@* 
    Note: For full editing support with separate language inputs, 
    you would need a more complex editor that allows adding translations
    for each language. This is a simple single-field editor.
*@