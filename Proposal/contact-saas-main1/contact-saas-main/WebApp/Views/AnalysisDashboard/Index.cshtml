@model WebApp.ViewModels.AnalysisDashboardViewModel
@{
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <title>Analysis Dashboard</title>
</head>
<body>
<div class="col-md-12">
    <h3>Results</h3>
    <p>
        <a asp-controller="Result" asp-action="Create" class="btn btn-success">Create New Result</a>
    </p>
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var result in Model.Results)
        {
            <tr>
                <td>@result.ResultName</td>
                <td>@result.ResultDescription</td>
                <td>@result.CreatedAt.ToShortDateString()</td>
                <td>
                    <a asp-controller="Result" asp-action="Edit" asp-route-id="@result.Id">Edit</a> |
                    <a asp-controller="Result" asp-action="Details" asp-route-id="@result.Id">Details</a> |
                    <a asp-controller="Result" asp-action="Delete" asp-route-id="@result.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
</body>
</html>