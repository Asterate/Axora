@model List<App.Domain.Entities.Company>
@{
    ViewData["Title"] = "Company Approval/Rejection Log";
    var approvedCompanies = Model.Where(c => c.CompanyStatus == App.Domain.Entities.ECompanyStatus.Approved).ToList();
    var rejectedCompanies = Model.Where(c => c.CompanyStatus == App.Domain.Entities.ECompanyStatus.Rejected).ToList();
}

<h1>Company Approval/Rejection Log</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No companies have been approved or rejected yet.
    </div>
}
else
{
    <!-- Approved Companies -->
    <h2>Approved Companies (@approvedCompanies.Count)</h2>
    @if (approvedCompanies.Count > 0)
    {
        <div class="table-responsive mb-5">
            <table class="table table-striped table-hover">
                <thead class="thead-success">
                    <tr>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>Phone Number</th>
                        <th>Email</th>
                        <th>Created By</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in approvedCompanies)
                    {
                        <tr>
                            <td>@company.CompanyName</td>
                            <td>@company.CompanyAddress</td>
                            <td>@company.CompanyPhoneNumber</td>
                            <td>@company.CompanyEmail</td>
                            <td>@(company.CompanyUsers.FirstOrDefault()?.AppUser?.UserName ?? "Unknown")</td>
                            <td>@(company.CompanyUsers.FirstOrDefault()?.Roles.ToString() ?? "None")</td>
                            <td><span class="badge badge-success">Approved</span></td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@company.Id" class="btn btn-sm btn-primary">
                                    <span class="oi oi-pencil"></span> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@company.Id" class="btn btn-sm btn-danger ml-1">
                                    <span class="oi oi-trash"></span> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning mb-5">No approved companies.</div>
    }

    <!-- Rejected Companies -->
    <h2>Rejected Companies (@rejectedCompanies.Count)</h2>
    @if (rejectedCompanies.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="thead-danger">
                    <tr>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>Phone Number</th>
                        <th>Email</th>
                        <th>Created By</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in rejectedCompanies)
                    {
                        <tr>
                            <td>@company.CompanyName</td>
                            <td>@company.CompanyAddress</td>
                            <td>@company.CompanyPhoneNumber</td>
                            <td>@company.CompanyEmail</td>
                            <td>@(company.CompanyUsers.FirstOrDefault()?.AppUser?.UserName ?? "Unknown")</td>
                            <td>@(company.CompanyUsers.FirstOrDefault()?.Roles.ToString() ?? "None")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@company.Id" class="btn btn-sm btn-primary">
                                    <span class="oi oi-pencil"></span> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@company.Id" class="btn btn-sm btn-danger ml-1">
                                    <span class="oi oi-trash"></span> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">No rejected companies.</div>
    }
}

<a asp-action="Pending" class="btn btn-secondary mt-4">
    <span class="oi oi-arrow-left"></span> Back to Pending Companies
</a>
