@model List<App.Domain.Entities.Company>
@{
    ViewData["Title"] = "Pending Companies";
}

<h1>Pending Companies</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No pending companies to review.
    </div>
}
else
{
    <div class="row justify-content-center">
        @foreach (var company in Model)
        {
            <div class="col-md-8 col-lg-6 mb-4">
                <div class="card h-100 shadow-lg">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">@company.CompanyName</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            <strong>Address:</strong> @company.CompanyAddress<br>
                            <strong>Phone:</strong> @company.CompanyPhoneNumber<br>
                            <strong>Email:</strong> @company.CompanyEmail<br>
                            <strong>Created By:</strong> @(company.CompanyUsers.FirstOrDefault()?.AppUser?.UserName ?? "Unknown")
                        </p>
                    </div>
                    <div class="card-footer bg-light">
                        <div class="d-flex justify-content-between">
                            <form asp-area="Root" asp-controller="Companies" asp-action="Reject" asp-route-id="@company.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <span class="oi oi-x"></span> Reject
                                </button>
                            </form>

                            <form asp-area="Root" asp-controller="Companies" asp-action="Approve" asp-route-id="@company.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-lg">
                                    <span class="oi oi-check"></span> Approve
                                </button>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-action="Log" class="btn btn-secondary mt-3">
    <span class="oi oi-list"></span> View Approval/Rejection Log
</a>
