@model IEnumerable<App.Domain.Entities.TeacherCertificate>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Teacher)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Language)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Level)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TeacherCertificateGivenOut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TeacherCertificateName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TeacherCertificateDescription)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Teacher.TeacherAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Language.LanguageDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Level.LevelDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TeacherCertificateGivenOut)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TeacherCertificateName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TeacherCertificateDescription)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
