@model IEnumerable<App.Domain.Entities.Schedule>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Availability)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EScheduleType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleStartAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleEndAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleCreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleModifiedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleDeletedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ScheduleEnvironment)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Availability.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EScheduleType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleStartAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleEndAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleCreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleModifiedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleDeletedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ScheduleEnvironment)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
