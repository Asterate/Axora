@model App.Domain.Entities.Enrollment

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Enrollment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="CourseId" class="control-label"></label>
                <select asp-for="CourseId" class ="form-control" asp-items="ViewBag.CourseId"></select>
            </div>
            <div class="form-group">
                <label asp-for="StudentId" class="control-label"></label>
                <select asp-for="StudentId" class ="form-control" asp-items="ViewBag.StudentId"></select>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentCreatedAt" class="control-label"></label>
                <input asp-for="EnrollmentCreatedAt" class="form-control" />
                <span asp-validation-for="EnrollmentCreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentModifiedAt" class="control-label"></label>
                <input asp-for="EnrollmentModifiedAt" class="form-control" />
                <span asp-validation-for="EnrollmentModifiedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentDeletedAt" class="control-label"></label>
                <input asp-for="EnrollmentDeletedAt" class="form-control" />
                <span asp-validation-for="EnrollmentDeletedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentSeason" class="control-label"></label>
                <input asp-for="EnrollmentSeason" class="form-control" />
                <span asp-validation-for="EnrollmentSeason" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="EnrollmentRepeat" /> @Html.DisplayNameFor(model => model.EnrollmentRepeat)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="EnrollmentPayStatus" class="control-label"></label>
                <input asp-for="EnrollmentPayStatus" class="form-control" />
                <span asp-validation-for="EnrollmentPayStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
