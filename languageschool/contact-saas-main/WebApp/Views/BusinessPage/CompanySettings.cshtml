@model  WebApp.ViewModels.CompanySettingsViewModel

@{
    ViewData["Title"] = "Company Settings";
}

<div class="container mt-4">
    <h1 class="display-4">@Model.Company.CompanyName- Settings</h1>
    <p>Manage your company configuration and preferences.</p>
    
    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h4>Company Configuration</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigTimeZone):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigTimeZone)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigAllowOneOnOneSessions):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigAllowOneOnOneSessions)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigEnableMaterialTracking):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigEnableMaterialTracking)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigThemeColour):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigThemeColour)</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigCompanyLogoPath):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigCompanyLogoPath)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigMaxStudentsPerCourse):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigMaxStudentsPerCourse)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigEnableCertificates):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigEnableCertificates)</p>
                            </div>
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigVisibility):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigVisibility)</p>
                            </div>
                        </div>
                    </div>
                    
                    <hr />
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <strong>@Html.DisplayNameFor(model => model.CompanyConfig.CompanyConfigUpdatedAt):</strong>
                                <p>@Html.DisplayFor(model => model.CompanyConfig.CompanyConfigUpdatedAt)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4>Languages and Levels</h4>
                </div>
                <div class="card-body">
                    @if (Model.Languages != null && Model.Languages.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Language Name</th>
                                        <th>Level</th>
                                        <th>Description</th>
                                        <th>Created At</th>
                                    </tr>
                                </thead>
                                <tbody id="languagesTableBody">
                                    @foreach (var language in Model.Languages)
                                    {
                                        <tr id="languageRow_@language.Id">
                                            <td><input type="text" class="form-control" value="@language.LanguageName" readonly /></td>
                                            <td><input type="text" class="form-control" value="@language.Level?.LevelName" readonly /></td>
                                            <td><input type="text" class="form-control" value="@language.LanguageDescription" readonly /></td>
                                            <td><input type="text" class="form-control" value="@language.LanguageCreatedAt.ToString("dd.MM.yyyy HH:mm")" readonly /></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p>No languages and levels configured.</p>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-12">
            <a asp-action="EditSettings" asp-route-id="@Model.Company.Id" class="btn btn-primary">
                <i class="fas fa-edit"></i> Edit Settings
            </a>
        </div>
    </div>
    
    <!-- Add Language Form -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h4>Add New Language</h4>
                </div>
                <div class="card-body">
                    <form asp-action="AddLanguage" method="post">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label for="languageName">Language Name</label>
                                <input type="text" class="form-control" id="languageName" name="languageName" required minlength="3" maxlength="128">
                            </div>
                            <div class="form-group col-md-4">
                                <label asp-for="NewLanguageLevelId">Level</label>
                                <select asp-for="NewLanguageLevelId" asp-items="Model.Levels" class="form-control" required>
                                    <option value="">Select Level</option>
                                </select>
                            </div>
                            <div class="form-group col-md-4">
                                <label for="languageDescription">Description</label>
                                <input type="text" class="form-control" id="languageDescription" name="languageDescription" required minlength="10" maxlength="128">
                            </div>
                        </div>
                        <input type="hidden" name="companyId" value="@Model.Company.Id">
                        <button type="submit" class="btn btn-primary">Add Language</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Delete Language Form (Hidden) -->
    <form id="deleteLanguageForm" asp-action="DeleteLanguage" method="post" style="display: none;">
        <input type="hidden" id="deleteLanguageId" name="languageId">
        <input type="hidden" id="deleteCompanyId" name="companyId" value="@Model.Company.Id">
    </form>
    
    <!-- JavaScript -->
    <script>
        function deleteLanguage(languageId) {
            if (confirm('Are you sure you want to delete this language?')) {
                document.getElementById('deleteLanguageId').value = languageId;
                document.getElementById('deleteLanguageForm').submit();
            }
        }
    </script>
</div>
