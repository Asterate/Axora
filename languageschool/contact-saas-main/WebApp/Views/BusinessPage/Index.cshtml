@using App.DAL.EF
@model List<App.Domain.Entities.Company>
@{
    ViewData["Title"] = "Business Page";
}

<div class="container mt-4">
    <h1 class="display-4">Welcome to the Business Page</h1>
    <p>Here you will find information about our language school services and offerings.</p>
    
    @* Company List for Owners *@
    @if (Model != null && Model.Any())
    {
        <div class="mt-5">
            <h2>My Companies</h2>
            <table class="table table-striped table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>Phone Number</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var company in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => company.CompanyName)</td>
                            <td>@Html.DisplayFor(modelItem => company.CompanyAddress)</td>
                            <td>@Html.DisplayFor(modelItem => company.CompanyPhoneNumber)</td>
                            <td>@Html.DisplayFor(modelItem => company.CompanyEmail)</td>
                            <td>
                                @if (company.CompanyStatus == App.Domain.Entities.ECompanyStatus.Approved)
                                {
                                    <span class="badge badge-success">Approved</span>
                                }
                                else if (company.CompanyStatus == App.Domain.Entities.ECompanyStatus.Pending)
                                {
                                    <span class="badge badge-warning">Pending</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Rejected</span>
                                }
                            </td>
                            <td>
                                <a asp-action="CompanyDesktop" asp-route-id="@company.Id" class="btn btn-info btn-sm">
                                    <i class="fas fa-desktop"></i> Desktop
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    
    @* Company Operations Buttons *@
    <div class="mt-4">
        <a asp-action="CreateCompany" class="btn btn-primary btn-lg">
            <i class="fas fa-building"></i> Create New Company
        </a>
    </div>
</div>
