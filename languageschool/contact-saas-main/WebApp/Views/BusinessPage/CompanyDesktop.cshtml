@model WebApp.Areas.Root.ViewModels.CompanyDesktopViewModel
@{
    ViewData["Title"] = "Company Desktop";
}

<div class="container mt-4">
    <h1 class="display-4">@Model.Company.CompanyName - Company Desktop</h1>
    <p>Here you can manage operations for @Model.Company.CompanyName.</p>
    
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Company Information</h4>
                </div>
                <div class="card-body">
                    <p><strong>Address:</strong> @Model.Company.CompanyAddress</p>
                    <p><strong>Phone Number:</strong> @Model.Company.CompanyPhoneNumber</p>
                    <p><strong>Email:</strong> @Model.Company.CompanyEmail</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Company Operations</h4>
                </div>
                <div class="card-body">
                    <a asp-action="CompanyAccount" asp-route-id="@Model.Company.Id" class="btn btn-success btn-block mb-3">
                        <i class="fas fa-user-plus"></i> Manage Company Account
                    </a>
                    <a asp-action="CompanySettings" asp-route-id="@Model.Company.Id" class="btn btn-info btn-block mb-3">
                        <i class="fas fa-cog"></i> Company Settings
                    </a>
                    <a href="#" class="btn btn-warning btn-block">
                        <i class="fas fa-chart-line"></i> View Reports
                    </a>
                    <a asp-action="CreateCourse" asp-controller="CoursePage" asp-route-id="@Model.Company.Id" class="btn btn-primary mb-3">
                        Create Course
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row mt-4">
    <div class="col-md-12">
        <h2>Courses</h2>
        <hr />
        <hr />

        @if (Model.Courses != null && Model.Courses.Any())
        {
            <table class="table table-bordered">
                <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Language</th>
                    <th>Level</th>
                    <th>Teacher</th>
                    <th>Season</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>@course.CourseName</td>
                        <td>@course.Language?.LanguageName</td>
                        <td>@course.Level?.LevelName</td>
                        <td>@course.Teacher?.TeacherFirstName @course.Teacher?.TeacherLastName</td>
                        <td>@course.CourseSeason</td>
                        <td>
                            <a asp-action="CourseDesktop" asp-controller="CoursePage" asp-route-id="@course.Id" class="btn btn-sm btn-info">
                                Course Desktop
                            </a>
                            <form asp-action="CourseDelete" asp-controller="CoursePage" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@course.Id" />
                                <input type="hidden" name="companyId" value="@Model.Company.Id" />
                                <button type="submit" class="btn btn-sm btn-info">Delete</button>
                            </form>
                            <a asp-action="EditCourse" asp-controller="CoursePage" asp-route-id="@course.Id" class="btn btn-sm btn-info">
                                Edit
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <p>No courses found for this company. Create your first course above.</p>
        }
    </div>
</div>