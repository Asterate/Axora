@model App.Domain.Entities.Company
@{
    ViewData["Title"] = "Company Desktop";
}

<div class="container mt-4">
    <h1 class="display-4">@Model.CompanyName - Company Desktop</h1>
    <p>Here you can manage operations for @Model.CompanyName.</p>
    
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Company Information</h4>
                </div>
                <div class="card-body">
                    <p><strong>Address:</strong> @Model.CompanyAddress</p>
                    <p><strong>Phone Number:</strong> @Model.CompanyPhoneNumber</p>
                    <p><strong>Email:</strong> @Model.CompanyEmail</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Company Operations</h4>
                </div>
                <div class="card-body">
                    <a asp-action="CompanyAccount" asp-route-id="@Model.Id" class="btn btn-success btn-block mb-3">
                        <i class="fas fa-user-plus"></i> Manage Company Account
                    </a>
                    <a href="#" class="btn btn-info btn-block mb-3">
                        <i class="fas fa-cog"></i> Company Settings
                    </a>
                    <a href="#" class="btn btn-warning btn-block">
                        <i class="fas fa-chart-line"></i> View Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
