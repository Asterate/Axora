@model WebApp.ViewModels.HomeViewModel

@{
    ViewData["Title"] = Model.IsAuthenticated ? "Public Courses" : "Welcome to Language Platform";
}

@if (!Model.IsAuthenticated)
{
    <div class="home-container">
        <!-- Hero Section -->
        <section class="hero-section">
            <div class="container">
                <div class="hero-content">
                    <h1 class="hero-title">Welcome to Your Language Learning Journey</h1>
                    <p class="hero-subtitle">Discover, learn, and master new languages with our comprehensive platform. Connect with expert teachers, interactive courses, and a vibrant learning community.</p>
                    <div class="hero-buttons">
                        <a href="/Identity/Account/Login" class="btn btn-primary btn-large">Sign In</a>
                        <a href="/Identity/Account/Register" class="btn btn-outline-light btn-large">Create Account</a>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="language-icons">
                        <div class="language-icon">🇬🇧 English</div>
                        <div class="language-icon">🇪🇸 Spanish</div>
                        <div class="language-icon">🇫🇷 French</div>
                        <div class="language-icon">🇩🇪 German</div>
                        <div class="language-icon">🇨🇳 Chinese</div>
                        <div class="language-icon">🇯🇵 Japanese</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="features-section">
            <div class="container">
                <div class="section-header">
                    <h2>Why Choose Our Platform?</h2>
                    <p>Experience the future of language learning</p>
                </div>
                
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">👨‍🏫</div>
                        <h3>Expert Teachers</h3>
                        <p>Learn from experienced and certified language instructors from around the world</p>
                    </div>
                    
                    <div class="feature-card">
                        <div class="feature-icon">📚</div>
                        <h3>Comprehensive Courses</h3>
                        <p>Structured curricula with interactive materials for all language levels</p>
                    </div>
                    
                    <div class="feature-card">
                        <div class="feature-icon">⏰</div>
                        <h3>Flexible Scheduling</h3>
                        <p>Book lessons at your convenience with our smart scheduling system</p>
                    </div>
                    
                    <div class="feature-card">
                        <div class="feature-icon">🎯</div>
                        <h3>Personalized Learning</h3>
                        <p>Tailored learning paths based on your goals and progress</p>
                    </div>
                    
                    <div class="feature-card">
                        <div class="feature-icon">💬</div>
                        <h3>Interactive Sessions</h3>
                        <p>Engage in real-time conversations and practice speaking skills</p>
                    </div>
                    
                    <div class="feature-card">
                        <div class="feature-icon">📊</div>
                        <h3>Progress Tracking</h3>
                        <p>Monitor your learning journey with detailed analytics and reports</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section">
            <div class="container">
                <div class="cta-content">
                    <h2>Ready to Start Your Language Journey?</h2>
                    <p>Join thousands of learners who have already transformed their language skills</p>
                    <a href="/Identity/Account/Register" class="btn btn-primary btn-large">Get Started Free</a>
                </div>
            </div>
        </section>
    </div>
}
else
{
    <div class="home-container">
        <!-- Welcome Section -->
        <section class="welcome-section">
            <div class="container">
                <div class="welcome-content">
                    <h1 class="welcome-title">Welcome back, @Model.UserName!</h1>
                    <p class="welcome-subtitle">Explore our public courses and continue your language learning journey</p>
                </div>
            </div>
        </section>

        <!-- Courses Section -->
        <section class="courses-section">
            <div class="container">
                <div class="section-header">
                    <h2>Public Courses</h2>
                    <p>Discover courses from top language schools and instructors</p>
                </div>
                
                @if (Model.PublicCourses != null && Model.PublicCourses.Any())
                {
                    <div class="courses-grid">
                        @foreach (var course in Model.PublicCourses)
                        {
                            <div class="course-card">
                                <div class="course-image">
                                    <div class="course-placeholder">
                                        <span class="course-initial">@course.CourseName.Substring(0, 1)</span>
                                    </div>
                                </div>
                                <div class="course-content">
                                    <div class="course-meta">
                                        <span class="course-language">@course.Language?.LanguageName</span>
                                        <span class="course-level">@course.Level?.LevelName</span>
                                    </div>
                                    <h3 class="course-title">@course.CourseName</h3>
                                    <p class="course-description">@course.CourseDescription</p>
                                    <div class="course-teacher">
                                        <span class="teacher-name">👨‍🏫 @course.Teacher?.TeacherFirstName @course.Teacher?.TeacherLastName</span>
                                    </div>
                                    <div class="course-company">
                                        <span class="company-name">🏢 @course.Company?.CompanyName</span>
                                    </div>
                                    <div class="course-season">
                                        <span class="season">📅 @course.CourseSeason</span>
                                    </div>
                                    <div class="course-actions">
                                        <a asp-action="CourseDesktop" asp-controller="CoursePage" asp-route-id="@course.Id" class="btn btn-primary">View Course</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="no-courses">
                        <div class="no-courses-icon">📚</div>
                        <h3>No public courses available</h3>
                        <p>Check back later for new courses or contact us to add your courses</p>
                    </div>
                }
            </div>
        </section>
    </div>
}

<style>
    /* Home Page Styling */
    .home-container {
        font-family: 'DM Sans', sans-serif;
    }

    /* Welcome Section (Authenticated) */
    .welcome-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 0;
    }

    .welcome-content {
        text-align: center;
    }

    .welcome-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 900;
        margin-bottom: 15px;
        line-height: 1.2;
    }

    .welcome-subtitle {
        font-size: 1.2rem;
        opacity: 0.95;
        line-height: 1.6;
    }

    /* Courses Section (Authenticated) */
    .courses-section {
        padding: 80px 0;
        background: #f8f9fa;
    }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }

    .course-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .course-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
    }

    .course-image {
        height: 180px;
        overflow: hidden;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .course-placeholder {
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

    .course-initial {
        font-size: 2.5rem;
        font-weight: 700;
        color: white;
    }

    .course-content {
        padding: 25px;
    }

    .course-meta {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .course-language, .course-level {
        background: #e3f2fd;
        color: #1976d2;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .course-level {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .course-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .course-description {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.5;
        margin-bottom: 15px;
    }

    .course-teacher, .course-company, .course-season {
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: #555;
    }

    .teacher-name, .company-name, .season {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .course-actions {
        margin-top: 20px;
    }

    .course-actions .btn {
        width: 100%;
        padding: 12px 20px;
        font-size: 1rem;
        border-radius: 8px;
    }

    .no-courses {
        text-align: center;
        padding: 80px 20px;
    }

    .no-courses-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .no-courses h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    .no-courses p {
        color: #666;
        font-size: 1.1rem;
    }

    /* Hero Section (Unauthenticated) */
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .hero-content {
        max-width: 600px;
        margin-bottom: 40px;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 20px;
        line-height: 1.2;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        margin-bottom: 30px;
        opacity: 0.95;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn-large {
        padding: 15px 30px;
        font-size: 1.1rem;
        border-radius: 50px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: #ff6b6b;
        border: none;
        color: white;
    }

    .btn-primary:hover {
        background: #ee5a52;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(255, 107, 107, 0.3);
    }

    .btn-outline-light {
        background: transparent;
        border: 2px solid white;
        color: white;
    }

    .btn-outline-light:hover {
        background: white;
        color: #667eea;
        transform: translateY(-2px);
    }

    /* Language Icons */
    .language-icons {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 40px;
    }

    .language-icon {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        font-size: 1.2rem;
        font-weight: 500;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .language-icon:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    /* Features Section */
    .features-section {
        padding: 100px 0;
        background: #f8f9fa;
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 15px;
    }

    .section-header p {
        font-size: 1.1rem;
        color: #666;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
    }

    .feature-card {
        background: white;
        padding: 40px 30px;
        border-radius: 20px;
        text-align: center;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .feature-icon {
        font-size: 3rem;
        margin-bottom: 20px;
    }

    .feature-card h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 15px;
    }

    .feature-card p {
        color: #666;
        line-height: 1.6;
        font-size: 1rem;
    }

    /* CTA Section */
    .cta-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 0;
        text-align: center;
    }

    .cta-content h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .cta-content p {
        font-size: 1.2rem;
        margin-bottom: 30px;
        opacity: 0.95;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .welcome-section {
            padding: 40px 0;
        }

        .welcome-title {
            font-size: 2rem;
        }

        .welcome-subtitle {
            font-size: 1.1rem;
        }

        .courses-section {
            padding: 60px 0;
        }

        .courses-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .hero-section {
            padding: 60px 0;
            min-height: auto;
        }
        
        .hero-title {
            font-size: 2.2rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }

        .language-icons {
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 30px;
        }

        .language-icon {
            padding: 15px;
            font-size: 1.1rem;
        }

        .section-header h2 {
            font-size: 2rem;
        }

        .cta-content h2 {
            font-size: 2rem;
        }

        .features-section {
            padding: 60px 0;
        }

        .cta-section {
            padding: 60px 0;
        }
    }

    @@media (max-width: 576px) {
        .welcome-title {
            font-size: 1.6rem;
        }

        .courses-grid {
            gap: 15px;
        }

        .course-content {
            padding: 20px;
        }

        .hero-section {
            padding: 40px 0;
            min-height: auto;
        }
        
        .hero-title {
            font-size: 1.8rem;
        }

        .hero-subtitle {
            font-size: 1rem;
            margin-bottom: 20px;
        }

        .hero-buttons {
            flex-direction: column;
            width: 100%;
            gap: 10px;
        }

        .btn-large {
            width: 100%;
            justify-content: center;
            padding: 12px 20px;
            font-size: 1rem;
        }

        .language-icons {
            grid-template-columns: 1fr;
        }

        .language-icon {
            padding: 12px;
            font-size: 1rem;
        }

        .features-grid {
            gap: 20px;
        }

        .feature-card {
            padding: 30px 20px;
        }

        .feature-icon {
            font-size: 2.5rem;
        }

        .feature-card h3 {
            font-size: 1.3rem;
        }

        .section-header h2 {
            font-size: 1.8rem;
        }

        .cta-content h2 {
            font-size: 1.8rem;
        }
    }
</style>
