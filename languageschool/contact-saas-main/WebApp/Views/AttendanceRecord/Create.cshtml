            </div>
            <div class="form-group">
                <label asp-for="AttendanceRecordUpdatedAt" class="control-label"></label>
                <input asp-for="AttendanceRecordUpdatedAt" class="form-control" />
                <span asp-validation-for="AttendanceRecordUpdatedAt" class="text-danger"></span>
