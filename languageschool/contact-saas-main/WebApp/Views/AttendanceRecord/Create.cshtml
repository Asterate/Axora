@model App.Domain.Entities.AttendanceRecord

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>AttendanceRecord</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="EnrollmentId" class="control-label"></label>
                <select asp-for="EnrollmentId" class ="form-control" asp-items="ViewBag.EnrollmentId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ScheduleId" class="control-label"></label>
                <select asp-for="ScheduleId" class ="form-control" asp-items="ViewBag.ScheduleId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmedById" class="control-label"></label>
                <select asp-for="ConfirmedById" class ="form-control" asp-items="ViewBag.ConfirmedById"></select>
            </div>
            <div class="form-group">
                <label asp-for="AttendanceRecordCreatedAt" class="control-label"></label>
                <input asp-for="AttendanceRecordCreatedAt" class="form-control" />
