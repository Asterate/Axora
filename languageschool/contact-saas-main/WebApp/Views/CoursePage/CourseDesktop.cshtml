@model WebApp.ViewModels.CourseDesktopViewModel

@{
    ViewData["Title"] = "Course Desktop: " + Model.Course.CourseName;
}

@section HeaderScripts {
    <link rel="stylesheet" href="~/css/course-desktop.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}


<!-- Hero -->
<div class="course-hero">
    <div class="container">
        <div class="label">Course Overview</div>
        <h1>@Model.Course.CourseName</h1>
        <p class="description">@Model.Course.CourseDescription</p>

        <div class="meta-chips">
            <span class="meta-chip">
                <i class="fas fa-language"></i>
                @Model.Course.Language?.LanguageName
            </span>
            <span class="meta-chip">
                <i class="fas fa-signal"></i>
                @Model.Course.Level?.LevelName
            </span>
            <span class="meta-chip">
                <i class="fas fa-chalkboard-teacher"></i>
                @Model.Course.Teacher?.TeacherFirstName @Model.Course.Teacher?.TeacherLastName
            </span>
            <span class="meta-chip">
                <i class="fas fa-calendar"></i>
                @Model.Course.CourseSeason
            </span>
        </div>

        <div class="hero-actions">
            <a asp-action="CompanyDesktop" asp-controller="BusinessPage" asp-route-id="@Model.Course.CompanyId" class="btn-ghost">
                <i class="fas fa-arrow-left"></i> Back to Company
            </a>
            @if (!Model.IsEnrolled)
            {
                <a asp-action="Enroll" asp-controller="CoursePage" asp-authorize-roles="admin, STUDENT, COMPANYOWNER, USER, support, None, billing" asp-route-id="@Model.Course.Id" class="btn-gold">
                    <i class="fas fa-user-plus"></i> Enroll in Course
                </a>
            }
            else
            {
                <span class="btn-ghost enrolled">
                    <i class="fas fa-check-circle"></i> Already Enrolled
                </span>
            }
            <a asp-action="TeacherDesktop" asp-controller="TeacherPage"  asp-route-id="@Model.Course.Id" class="btn-gold">
                <i class="fas fa-edit"></i> Teacher view
            </a>
            <a asp-action="EditCourse" asp-authorize-roles="admin, COMPANYMANAGER, COMPANYOWNER, support" asp-route-id="@Model.Course.Id" class="btn-gold">
                <i class="fas fa-edit"></i> Edit Course
            </a>
        </div>
    </div>
</div>

<!-- Content -->
<div class="content-grid" asp-authorize-roles="admin, TEACHER, COMPANYOWNER, support, COMPANYMANAGER">

    <!-- Schedule -->
    <div class="section-card full-width" asp-authorize-roles="admin, TEACHER, COMPANYOWNER, support">
        <div class="card-head">
            <div class="card-head-left">
                <div class="card-icon blue"><i class="fas fa-calendar-alt"></i></div>
                <h2>Schedule</h2>
            </div>
            <div class="card-head-right">
                <a asp-action="CreateSchedule" asp-controller="SchedulePage" asp-authorize-roles="admin, TEACHER, COMPANYOWNER, support" asp-route-courseId="@Model.Course.Id" class="btn-gold">
                    <i class="fas fa-plus"></i> Add Schedule
                </a>
            </div>
        </div>
        <div class="card-body-inner" >
            @if (Model.Schedules.Any())
            {
                <table class="schedule-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Type</th>
                            <th>Environment</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var schedule in Model.Schedules)
                    {
                        <tr>
                            <td>@schedule.ScheduleStartAt.ToString("MMM dd, yyyy")</td>
                            <td>@schedule.ScheduleStartAt.ToString("HH:mm")</td>
                            <td>@schedule.ScheduleEndAt.ToString("HH:mm")</td>
                            <td><span class="badge-type">@schedule.EScheduleType</span></td>
                            <td>@schedule.ScheduleEnvironment</td>
                            <td>
                                <div class="schedule-actions">
                                    <a asp-action="EditSchedule" asp-authorize-roles="admin, TEACHER, COMPANYOWNER, support" asp-controller="SchedulePage" asp-route-id="@schedule.Id" class="btn-edit">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <form asp-action="DeleteSchedule" asp-authorize-roles="admin, TEACHER, COMPANYOWNER, support" asp-controller="SchedulePage" asp-route-id="@schedule.Id" asp-route-courseId="@Model.Course.Id" asp-route-courseId="@Model.Course.CompanyId" method="post" onsubmit="return confirm('Are you sure you want to delete this schedule?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-calendar-times"></i>
                    <p>@(Model.NoSchedulesMessage ?? "No schedule available yet. Add your first schedule to get started!")</p>
                </div>
            }
        </div>
    </div>

    <!-- Materials -->
    <div class="section-card full-width">
        <div class="card-head">
            <div class="card-head-left">
                <div class="card-icon green"><i class="fas fa-book"></i></div>
                <h2>Course Materials</h2>
            </div>
        </div>
        <div class="card-body-inner">
            @if (Model.Materials != null && Model.Materials.Any())
            {
                <div class="materials-grid">
                    @foreach (var material in Model.Materials)
                    {
                        <div class="material-card">
                            <h5>@material.MaterialName</h5>
                            <p>@material.MaterialDescription</p>
                            <div class="material-tags">
                                <span class="tag tag-version">v@material.MaterialVersion</span>
                                <span class="tag tag-env">@material.MaterialEnvironment</span>
                            </div>
                            <div class="material-actions">
                                <a asp-action="EditMaterial" asp-controller="MaterialPage" asp-route-materialId="@material.Id" class="btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form asp-action="DeleteMaterial" asp-controller="MaterialPage" asp-route-materialId="@material.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this material?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                                <a href="#" class="btn-download">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-folder-open"></i>
                    <p>@(Model.NoMaterialsMessage ?? "No materials available yet. Add your first material to get started!")</p>
                </div>
            }
        </div>
    </div>

    <!-- Add Material CTA -->
    <div class="add-material-cta">
        <div>
            <h3>Ready to add new material?</h3>
            <p>Upload resources, documents and files for your students.</p>
        </div>
        <a asp-action="CreateMaterial" asp-controller="MaterialPage" asp-route-courseId="@Model.Course.Id" class="btn-gold">
            <i class="fas fa-plus"></i> Add Material
        </a>
    </div>

</div>
