@model WebApp.ViewModels.CreateCourseViewModel

<h1>@(Model.CourseId.HasValue ? "Edit Course" : "Create Course"): @Model.CompanyName</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="@(Model.CourseId.HasValue ? "EditCourse" : "CreateCourse")"
              asp-controller="CoursePage"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CourseId" />
            <input type="hidden" asp-for="CompanyId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="CourseName"></label>
                <input asp-for="CourseName" class="form-control" required />
                <span asp-validation-for="CourseName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CourseDescription"></label>
                <textarea asp-for="CourseDescription" class="form-control" rows="4" ></textarea>
                <span asp-validation-for="CourseDescription" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CourseSeason"></label>
                <input asp-for="CourseSeason" class="form-control"  />
                <span asp-validation-for="CourseSeason" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LanguageId"></label>
                <select asp-for="LanguageId" class="form-control" id="languageSelect">
                    <option value="">Select a language</option>
                    @foreach (var lang in Model.Languages!)
                    {
                        <option value="@lang.Value">@lang.Text</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label asp-for="LevelId"></label>
                <select asp-for="LevelId" class="form-control" id="levelSelect">
                    <option value="">Select a level</option>
                </select>
            </div>


            <div class="form-group">
                <label asp-for="TeacherId"></label>
                <select asp-for="TeacherId" asp-items="Model.Teachers" class="form-control" >
                    <option value="">Select a teacher</option>
                </select>
            </div>

            <div class="form-group">
                @if (Model.CourseId.HasValue)
                {
                    <input type="submit" name="submit" value="Save Changes" class="btn btn-primary" />
                    <a asp-action="CourseDesktop" asp-controller="CoursePage" asp-route-id="@Model.CourseId" class="btn btn-default">Cancel</a>
                }
                else
                {
                    <input type="submit" name="submit" value="Create Course" class="btn btn-primary" />
                    <a asp-action="CompanyDesktop" asp-controller="BusinessPage" asp-route-id="@Model.CompanyId" class="btn btn-default">Cancel</a>
                }
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script>
    const languageLevelMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LanguageLevelMap));

    const languageSelect = document.getElementById("languageSelect");
    const levelSelect = document.getElementById("levelSelect");

    languageSelect.addEventListener("change", function () {
        const langId = this.value;

        // Clear previous options
        levelSelect.innerHTML = '<option value="">Select a level</option>';

        if (!langId || !languageLevelMap[langId]) return;

        // Add new options
        languageLevelMap[langId].forEach(lv => {
            const option = document.createElement("option");
            option.value = lv.Value;
            option.text = lv.Text;
            levelSelect.appendChild(option);
        });
    });

    // Pre-fill levels dropdown if language and level are already selected (edit mode)
    document.addEventListener("DOMContentLoaded", function() {
        const selectedLanguageId = "@Model.LanguageId";
        const selectedLevelId = "@Model.LevelId";

        if (selectedLanguageId && languageLevelMap[selectedLanguageId]) {
            // Clear and populate levels for selected language
            levelSelect.innerHTML = '<option value="">Select a level</option>';
            languageLevelMap[selectedLanguageId].forEach(lv => {
                const option = document.createElement("option");
                option.value = lv.Value;
                option.text = lv.Text;
                if (lv.Value === selectedLevelId) {
                    option.selected = true;
                }
                levelSelect.appendChild(option);
            });
        }
    });
</script>
}
