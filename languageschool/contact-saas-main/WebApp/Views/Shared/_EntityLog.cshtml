@model WebApp.ViewModels.EntityLogViewModel

<div class="section-card full-width">
    <div class="card-head">
        <div class="card-head-left">
            <div class="card-icon purple"><i class="@Model.EntityIcon"></i></div>
            <h2>@Model.EntityName</h2>
        </div>
    </div>
    <div class="card-body-inner">
        @if (Model.Items != null && Model.Items.Any())
        {
            <div class="entity-log-grid">
                @foreach (var item in Model.Items)
                {
                    <div class="entity-log-card">
                        <div class="entity-log-header">
                            @if (!string.IsNullOrEmpty(item.Icon))
                            {
                                <div class="entity-log-icon"><i class="@item.Icon"></i></div>
                            }
                            <div class="entity-log-title">
                                <h5>@item.Title</h5>
                                @if (!string.IsNullOrEmpty(item.Subtitle))
                                {
                                    <p class="entity-log-subtitle">@item.Subtitle</p>
                                }
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="entity-log-description">@item.Description</p>
                        }
                        
                        @if (item.AdditionalData != null && item.AdditionalData.Any())
                        {
                            <div class="entity-log-details">
                                @foreach (var data in item.AdditionalData)
                                {
                                    <div class="entity-log-detail">
                                        <span class="detail-label">@data.Key:</span>
                                        <span class="detail-value">@data.Value</span>
                                    </div>
                                }
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(item.BadgeText))
                        {
                            <span class="badge @item.BadgeClass">@item.BadgeText</span>
                        }
                        
                        <div class="entity-log-actions">
                            <a asp-action="@Model.LogPageAction" 
                               asp-controller="@Model.LogPageController"
                               asp-all-route-data="@(item.RouteValues)"
                               class="btn-gold">
                                <i class="@item.LogActionIcon"></i> @item.LogActionText
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="@Model.EntityIcon"></i>
                <p>@(Model.NoItemsMessage ?? $"No {Model.EntityName.ToLower()} available yet.")</p>
            </div>
        }
    </div>
</div>